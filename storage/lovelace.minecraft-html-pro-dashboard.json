{
  "version": 1,
  "minor_version": 1,
  "key": "lovelace.minecraft-html-pro-dashboard",
  "data": {
    "config": {
      "title": "Minecraft HTML Pro Dashboard",
      "views": [
        {
          "title": "Minecraft HTML Pro",
          "path": "minecraft-html-pro",
          "icon": "mdi:minecraft",
          "type": "panel",
          "cards": [
            {
              "type": "custom:html-pro-card",
              "do_not_parse": true,
              "ignore_line_breaks": true,
              "update_interval": 5000,
              "entities": [
                "light.living_room_lights",
                "light.bedroom_lights",
                "light.garden_light_strip",
                "switch.kitchen_socket",
                "climate.living_room_ac",
                "media_player.living_room_speaker",
                "lock.front_door",
                "binary_sensor.front_door_contact",
                "binary_sensor.living_room_presence",
                "binary_sensor.bedroom_presence",
                "binary_sensor.kitchen_presence",
                "sensor.living_room_temperature",
                "sensor.living_room_humidity",
                "sensor.bedroom_temperature",
                "sensor.bedroom_humidity",
                "sensor.kitchen_temperature",
                "sensor.outdoor_temperature",
                "sensor.outdoor_humidity",
                "sensor.pm25",
                "sensor.current_power",
                "sensor.energy_cost_today",
                "sensor.energy_cost_month",
                "weather.home",
                "sensor.time",
                "sensor.date",
                "scene.home_mode",
                "scene.good_night",
                "scene.welcome_home",
                "scene.away_mode"
              ],
              "content": "<style>\n  :host { display:block; }\n  ha-card { border:0; box-shadow:none; background:transparent; overflow:hidden; }\n  .mc-shell {\n    min-height: calc(100vh - 16px);\n    padding: 18px;\n    box-sizing: border-box;\n    display: grid;\n    grid-template-columns: 184px minmax(0, 1fr);\n    gap: 18px;\n    color: #fff;\n    font-family: var(--paper-font-body1_-_font-family, inherit);\n    background:\n      linear-gradient(180deg, rgba(18, 11, 7, .36), rgba(18, 11, 7, .54)),\n      url(\"/local/minecraft-dashboard/base-texture.jpg\") center / cover no-repeat;\n  }\n  h1, h2, h3, p { margin:0; font:inherit; }\n  button { font:inherit; }\n  .muted { color: rgba(255,255,255,.68); }\n  .side {\n    min-height: calc(100vh - 52px);\n    display: flex;\n    flex-direction: column;\n    gap: 18px;\n  }\n  .profile {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 4px 8px;\n  }\n  .profile img {\n    width: 54px;\n    height: 54px;\n    object-fit: cover;\n    border-radius: 15px;\n    border: 1px solid rgba(255,255,255,.2);\n    box-shadow: 0 16px 36px rgba(0,0,0,.26);\n  }\n  .profile b { display:block; font-size:16px; font-weight:950; }\n  .profile span { display:block; margin-top:3px; font-size:12px; color:#8ee46d; font-weight:900; }\n  .nav { display:grid; gap:7px; }\n  .nav button {\n    min-height: 45px;\n    border: 1px solid transparent;\n    border-radius: 15px;\n    padding: 0 12px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    color: rgba(255,255,255,.68);\n    background: transparent;\n    cursor: pointer;\n    text-align: left;\n    transition: transform .16s ease, background .16s ease, border-color .16s ease, color .16s ease;\n    text-shadow: 0 2px 14px rgba(0,0,0,.54);\n  }\n  .nav button:hover { transform: translateY(-1px); background: rgba(255,255,255,.07); color:#fff; }\n  .nav button.active { color:#fff; background: rgba(118, 166, 79, .22); border-color: rgba(175, 224, 112, .25); }\n  .nav ha-icon { --mdc-icon-size: 21px; color: currentColor; }\n  .side-art {\n    margin-top: auto;\n    min-height: 148px;\n    border-radius: 22px;\n    overflow: hidden;\n    box-shadow: 0 22px 58px rgba(0,0,0,.32);\n  }\n  .side-art img { width:100%; height:100%; object-fit:cover; display:block; }\n  .stage {\n    position: relative;\n    min-height: calc(100vh - 52px);\n    border-radius: 30px;\n    overflow: hidden;\n    background:\n      linear-gradient(90deg, rgba(15, 9, 5, .42), rgba(15, 9, 5, .04) 46%, rgba(15, 9, 5, .42)),\n      url(\"/local/minecraft-dashboard/stage-background.jpg\") center / cover no-repeat;\n    box-shadow: 0 32px 98px rgba(0,0,0,.38);\n  }\n  .stage::before {\n    content:\"\";\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    box-shadow: inset 0 0 0 1px rgba(255,255,255,.12), inset 0 -110px 190px rgba(0,0,0,.26);\n    z-index:0;\n  }\n  .page {\n    position:absolute;\n    inset:0;\n    z-index:1;\n    display:none;\n    padding:24px;\n    box-sizing:border-box;\n    overflow:auto;\n  }\n  .page.active { display:block; }\n  .home-grid {\n    min-height:100%;\n    display:grid;\n    grid-template-columns: minmax(0, 2.75fr) minmax(292px, .95fr);\n    grid-template-rows: auto 1fr auto;\n    grid-template-areas: \"hero rail\" \"spacer rail\" \"bottom rail\";\n    gap:16px;\n  }\n  .hero { grid-area:hero; max-width: 610px; text-shadow: 0 3px 18px rgba(0,0,0,.52); }\n  .hero h1 { font-size:30px; line-height:1.08; font-weight:950; }\n  .hero p { margin-top:8px; font-size:14px; color:rgba(255,255,255,.82); }\n  .weather-pill {\n    margin-top:15px;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    min-height:38px;\n    padding:0 13px 0 5px;\n    border-radius:999px;\n    background: rgba(18, 10, 5, .44);\n    border: 1px solid rgba(255,255,255,.14);\n    cursor:pointer;\n  }\n  .weather-icon {\n    width:32px;\n    height:32px;\n    border-radius: 12px;\n    display:grid;\n    place-items:center;\n    color:#ffd66d;\n    background:rgba(255,255,255,.12);\n  }\n  .weather-icon ha-icon { --mdc-icon-size:21px; }\n  .bottom { grid-area:bottom; display:grid; gap:16px; align-self:end; }\n  .section-title { display:flex; align-items:end; justify-content:space-between; gap:12px; margin-bottom:10px; text-shadow:0 3px 16px rgba(0,0,0,.55); }\n  .section-title h2 { font-size:17px; font-weight:950; }\n  .section-title p { font-size:12px; color:rgba(255,255,255,.68); }\n  .device-grid { display:grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap:12px; }\n  .device {\n    min-height:150px;\n    padding:15px;\n    box-sizing:border-box;\n    border:1px solid rgba(255,255,255,.52);\n    border-radius:18px;\n    display:grid;\n    grid-template-rows:auto 1fr auto;\n    gap:10px;\n    background:rgba(243,239,229,.95);\n    color:#2b221c;\n    box-shadow:0 18px 48px rgba(0,0,0,.26);\n    cursor:pointer;\n    transition:transform .16s ease, box-shadow .16s ease, background .18s ease;\n  }\n  .device:hover, .room:hover, .scene:hover { transform: translateY(-2px); }\n  .device:active, .scene:active { transform: scale(.985); }\n  .device.on-yellow { background:#e9c875; color:#31230e; }\n  .device.on-blue { background:#8fc2ea; color:#142a3d; }\n  .device.on-purple { background:#b595df; color:#291a3f; }\n  .device.on-green { background:#9dcb78; color:#1c3013; }\n  .device.on-red { background:#db8d75; color:#3c1d14; }\n  .device.off { background:rgba(243,239,229,.95); color:#2b221c; }\n  .device.unavailable { filter:saturate(.45); opacity:.76; }\n  .device-top { display:flex; justify-content:space-between; align-items:flex-start; gap:8px; }\n  .device img { width:54px; height:54px; object-fit:cover; border-radius:15px; border:1px solid rgba(0,0,0,.1); }\n  .badge { min-height:24px; min-width:34px; padding:0 8px; border-radius:999px; display:grid; place-items:center; font-size:11px; font-weight:950; background:rgba(0,0,0,.1); }\n  .device-copy { align-self:end; }\n  .device-copy b { display:block; font-size:15px; line-height:1.1; font-weight:950; overflow-wrap:anywhere; }\n  .device-copy span { display:block; margin-top:4px; font-size:12px; color:rgba(37,27,19,.62); font-weight:800; }\n  .control-row { display:flex; align-items:center; justify-content:space-between; gap:8px; }\n  .state-word { font-size:13px; font-weight:950; }\n  .switch { width:43px; height:24px; border-radius:999px; background:rgba(35,27,21,.18); position:relative; flex:0 0 auto; }\n  .switch::after { content:\"\"; position:absolute; top:4px; left:4px; width:16px; height:16px; border-radius:999px; background:#f7f0e7; box-shadow:0 2px 8px rgba(0,0,0,.2); transition:left .18s ease; }\n  .switch.on { background:#5fa848; }\n  .switch.on::after { left:23px; }\n  .room-grid { display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:12px; }\n  .room { min-height:148px; aspect-ratio: 4 / 3; position:relative; overflow:hidden; border-radius:20px; border:1px solid rgba(255,255,255,.14); box-shadow:0 18px 52px rgba(0,0,0,.28); cursor:pointer; }\n  .room img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }\n  .room::after { content:\"\"; position:absolute; inset:0; background:linear-gradient(180deg, transparent 38%, rgba(12,8,5,.64)); }\n  .room div { position:absolute; left:14px; right:14px; bottom:14px; z-index:1; text-shadow:0 3px 14px rgba(0,0,0,.75); }\n  .room b { display:block; font-size:17px; font-weight:950; }\n  .room span { display:block; margin-top:3px; font-size:12px; color:rgba(255,255,255,.76); font-weight:850; }\n  .rail { grid-area:rail; display:grid; gap:14px; align-content:start; }\n  .glass {\n    border-radius:20px;\n    padding:15px;\n    background:rgba(32,14,3,.94);\n    border:1px solid rgba(255,255,255,.11);\n    box-shadow:0 20px 58px rgba(0,0,0,.24);\n  }\n  .clock-card { display:flex; justify-content:space-between; align-items:center; gap:12px; min-height:58px; }\n  .clock-time { font-size:30px; line-height:1; font-weight:950; }\n  .clock-date { margin-top:4px; font-size:12px; color:rgba(255,255,255,.68); }\n  .metric-list { display:grid; gap:12px; margin-top:12px; }\n  .metric { display:grid; grid-template-columns:30px 1fr auto; align-items:center; gap:10px; }\n  .dot { width:28px; height:28px; border-radius:10px; display:grid; place-items:center; font-weight:950; }\n  .dot.temp { background:rgba(216,82,72,.22); color:#ff958d; }\n  .dot.hum { background:rgba(74,151,226,.22); color:#94ceff; }\n  .dot.air { background:rgba(112,185,86,.22); color:#9ee779; }\n  .metric small { color:rgba(255,255,255,.64); font-size:12px; }\n  .metric b { font-size:14px; font-weight:950; }\n  .energy-main { margin-top:5px; font-size:36px; line-height:1; font-weight:950; }\n  .energy-main small { font-size:13px; color:rgba(255,255,255,.66); }\n  .bars { height:80px; display:flex; align-items:end; gap:6px; margin-top:14px; }\n  .bars span { flex:1; min-height:12px; border-radius:6px 6px 2px 2px; background:linear-gradient(180deg, #91e571, #457a35); }\n  .scene-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }\n  .scene { min-height:82px; border:1px solid rgba(255,255,255,.14); border-radius:16px; padding:10px; color:#fff; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:5px; cursor:pointer; }\n  .scene ha-icon { --mdc-icon-size:23px; }\n  .scene b { font-size:13px; font-weight:950; }\n  .scene span { font-size:11px; color:rgba(255,255,255,.74); }\n  .scene.home { background:rgba(142,176,74,.55); }\n  .scene.night { background:rgba(38,62,103,.58); }\n  .scene.welcome { background:rgba(175,91,52,.55); }\n  .scene.away { background:rgba(84,58,130,.58); }\n  .subpage-head { margin-bottom:16px; display:flex; align-items:center; gap:12px; text-shadow:0 3px 18px rgba(0,0,0,.55); }\n  .subpage-head ha-icon { --mdc-icon-size:30px; }\n  .subpage-head h2 { font-size:26px; line-height:1.1; font-weight:950; }\n  .subpage-head p { margin-top:4px; color:rgba(255,255,255,.7); font-size:13px; }\n  .panel-grid { display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:12px; }\n  .wide-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:12px; }\n  .entity-row { display:flex; align-items:center; justify-content:space-between; gap:10px; min-height:46px; border-radius:14px; padding:10px 12px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.1); }\n  .entity-row span { color:rgba(255,255,255,.68); font-size:12px; }\n  .entity-row b { font-weight:950; }\n  .log-list { display:grid; gap:10px; }\n  .log { border-left:4px solid #8ee46d; }\n  .log.warn { border-left-color:#ffd36b; }\n  .log.danger { border-left-color:#ff8f83; }\n  @media (max-width: 1180px) {\n    .mc-shell { grid-template-columns:78px minmax(0, 1fr); }\n    .profile .copy, .nav span, .side-art { display:none; }\n    .nav button { justify-content:center; padding:0; }\n    .home-grid { grid-template-columns:1fr; grid-template-areas:\"hero\" \"bottom\" \"rail\"; }\n    .rail { grid-template-columns:repeat(2, minmax(0, 1fr)); }\n    .device-grid { grid-template-columns:repeat(3, minmax(0, 1fr)); }\n    .panel-grid { grid-template-columns:repeat(2, minmax(0, 1fr)); }\n  }\n  @media (max-width: 760px) {\n    .mc-shell { grid-template-columns:1fr; padding:10px; }\n    .side { min-height:auto; }\n    .profile, .side-art { display:none; }\n    .nav { grid-template-columns:repeat(6, minmax(0, 1fr)); }\n    .nav button { min-height:42px; border-radius:13px; }\n    .stage { min-height:calc(100vh - 76px); border-radius:22px; }\n    .page { padding:14px; }\n    .hero h1 { font-size:24px; }\n    .device-grid, .room-grid, .rail, .panel-grid, .wide-grid { grid-template-columns:1fr; }\n  }\n</style>\n\n<div class=\"mc-shell\">\n  <aside class=\"side\">\n    <div class=\"profile\">\n      <img src=\"/local/minecraft-dashboard/avatar-steve.jpg\" alt=\"\">\n      <div class=\"copy\"><b>Alex</b><span>在线</span></div>\n    </div>\n    <nav class=\"nav\">\n      <button class=\"active\" data-page=\"home\" type=\"button\"><ha-icon icon=\"mdi:home\"></ha-icon><span>首页</span></button>\n      <button data-page=\"devices\" type=\"button\"><ha-icon icon=\"mdi:devices\"></ha-icon><span>设备</span></button>\n      <button data-page=\"scenes\" type=\"button\"><ha-icon icon=\"mdi:palette-swatch\"></ha-icon><span>场景</span></button>\n      <button data-page=\"rooms\" type=\"button\"><ha-icon icon=\"mdi:door\"></ha-icon><span>房间</span></button>\n      <button data-page=\"energy\" type=\"button\"><ha-icon icon=\"mdi:lightning-bolt\"></ha-icon><span>能源</span></button>\n      <button data-page=\"logs\" type=\"button\"><ha-icon icon=\"mdi:clipboard-text-clock\"></ha-icon><span>日志</span></button>\n    </nav>\n    <div class=\"side-art\"><img src=\"/local/minecraft-dashboard/decor-wolf-lantern.jpg\" alt=\"\"></div>\n  </aside>\n\n  <main class=\"stage\">\n    <section class=\"page active\" data-page-view=\"home\">\n      <div class=\"home-grid\">\n        <header class=\"hero\">\n          <h1>我的世界智能宅</h1>\n          <p>用方块世界管理灯光、空调、能源和回家场景。</p>\n          <button class=\"weather-pill\" id=\"weather-action\" type=\"button\">\n            <span class=\"weather-icon\"><ha-icon id=\"weather-icon\" icon=\"mdi:weather-partly-cloudy\"></ha-icon></span>\n            <span><b id=\"weather-summary\">--</b> · <span id=\"out-temp\">--</span>°C</span>\n          </button>\n        </header>\n\n        <section class=\"bottom\">\n          <div>\n            <div class=\"section-title\"><h2>常用设备</h2><p>根据状态自动变色</p></div>\n            <div class=\"device-grid\">\n              <button class=\"device\" id=\"card-light\" data-entity=\"light.living_room_lights\" data-action=\"toggle\" type=\"button\">\n                <span class=\"device-top\"><img src=\"/local/minecraft-dashboard/icon-light.jpg\" alt=\"\"><em class=\"badge\" id=\"light-badge\">--</em></span>\n                <span class=\"device-copy\"><b>客厅灯光</b><span>Living Room</span></span>\n                <span class=\"control-row\"><strong class=\"state-word\" id=\"light-state\">--</strong><i class=\"switch\" id=\"light-switch\"></i></span>\n              </button>\n              <button class=\"device\" id=\"card-climate\" data-entity=\"climate.living_room_ac\" data-action=\"more-info\" type=\"button\">\n                <span class=\"device-top\"><img src=\"/local/minecraft-dashboard/icon-ac.jpg\" alt=\"\"><em class=\"badge\" id=\"climate-badge\">--</em></span>\n                <span class=\"device-copy\"><b>中央空调</b><span>Climate</span></span>\n                <span class=\"control-row\"><strong class=\"state-word\" id=\"climate-state\">--</strong><i class=\"switch\" id=\"climate-switch\"></i></span>\n              </button>\n              <button class=\"device\" id=\"card-media\" data-entity=\"media_player.living_room_speaker\" data-action=\"more-info\" type=\"button\">\n                <span class=\"device-top\"><img src=\"/local/minecraft-dashboard/icon-speaker.jpg\" alt=\"\"><em class=\"badge\">媒体</em></span>\n                <span class=\"device-copy\"><b>背景音乐</b><span>Media</span></span>\n                <span class=\"control-row\"><strong class=\"state-word\" id=\"media-state\">--</strong><ha-icon icon=\"mdi:music-note\"></ha-icon></span>\n              </button>\n              <button class=\"device\" id=\"card-lock\" data-entity=\"lock.front_door\" data-action=\"more-info\" type=\"button\">\n                <span class=\"device-top\"><img src=\"/local/minecraft-dashboard/icon-lock.jpg\" alt=\"\"><em class=\"badge\">安全</em></span>\n                <span class=\"device-copy\"><b>入户门锁</b><span>Door Lock</span></span>\n                <span class=\"control-row\"><strong class=\"state-word\" id=\"lock-state\">--</strong><ha-icon id=\"lock-icon\" icon=\"mdi:lock\"></ha-icon></span>\n              </button>\n              <button class=\"device\" id=\"card-garden\" data-entity=\"light.garden_light_strip\" data-action=\"toggle\" type=\"button\">\n                <span class=\"device-top\"><img src=\"/local/minecraft-dashboard/icon-garden-light.jpg\" alt=\"\"><em class=\"badge\">花园</em></span>\n                <span class=\"device-copy\"><b>花园灯带</b><span>Garden</span></span>\n                <span class=\"control-row\"><strong class=\"state-word\" id=\"garden-state\">--</strong><i class=\"switch\" id=\"garden-switch\"></i></span>\n              </button>\n            </div>\n          </div>\n\n          <div>\n            <div class=\"section-title\"><h2>房间入口</h2><p>空间状态快照</p></div>\n            <div class=\"room-grid\">\n              <button class=\"room\" data-page-jump=\"rooms\" type=\"button\"><img src=\"/local/minecraft-dashboard/room-living.jpg\" alt=\"\"><div><b>客厅</b><span id=\"room-living\">--</span></div></button>\n              <button class=\"room\" data-page-jump=\"rooms\" type=\"button\"><img src=\"/local/minecraft-dashboard/room-bedroom.jpg\" alt=\"\"><div><b>卧室</b><span id=\"room-bedroom\">--</span></div></button>\n              <button class=\"room\" data-page-jump=\"rooms\" type=\"button\"><img src=\"/local/minecraft-dashboard/room-kitchen.jpg\" alt=\"\"><div><b>厨房</b><span id=\"room-kitchen\">--</span></div></button>\n              <button class=\"room\" data-page-jump=\"rooms\" type=\"button\"><img src=\"/local/minecraft-dashboard/room-garden.jpg\" alt=\"\"><div><b>花园</b><span id=\"room-garden\">--</span></div></button>\n            </div>\n          </div>\n        </section>\n\n        <aside class=\"rail\">\n          <section class=\"glass clock-card\">\n            <div><div class=\"clock-time\" id=\"clock-time\">--:--</div><div class=\"clock-date\" id=\"clock-date\">----/--/--</div></div>\n            <ha-icon icon=\"mdi:clock-outline\"></ha-icon>\n          </section>\n          <section class=\"glass\">\n            <div class=\"section-title\"><h2>环境</h2><p>传感器</p></div>\n            <div class=\"metric-list\">\n              <div class=\"metric\"><span class=\"dot temp\">温</span><small>客厅温度</small><b><span id=\"env-temp\">--</span>°C</b></div>\n              <div class=\"metric\"><span class=\"dot hum\">湿</span><small>客厅湿度</small><b><span id=\"env-hum\">--</span>%</b></div>\n              <div class=\"metric\"><span class=\"dot air\">气</span><small>PM2.5</small><b><span id=\"pm25-value\">--</span></b></div>\n            </div>\n          </section>\n          <section class=\"glass\">\n            <p class=\"muted\">今日用电</p>\n            <div class=\"energy-main\"><span id=\"energy-today\">--</span><small> 度</small></div>\n            <div class=\"bars\" id=\"energy-bars\"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>\n          </section>\n          <section class=\"glass\">\n            <div class=\"section-title\"><h2>快捷场景</h2><p>二次确认</p></div>\n            <div class=\"scene-grid\">\n              <button class=\"scene home\" data-scene=\"scene.home_mode\" data-name=\"回家模式\" type=\"button\"><ha-icon icon=\"mdi:home-import-outline\"></ha-icon><b>回家</b><span>灯光与空调</span></button>\n              <button class=\"scene night\" data-scene=\"scene.good_night\" data-name=\"晚安模式\" type=\"button\"><ha-icon icon=\"mdi:weather-night\"></ha-icon><b>晚安</b><span>关闭公共区</span></button>\n              <button class=\"scene welcome\" data-scene=\"scene.welcome_home\" data-name=\"迎宾模式\" type=\"button\"><ha-icon icon=\"mdi:door-open\"></ha-icon><b>迎宾</b><span>打开主场景</span></button>\n              <button class=\"scene away\" data-scene=\"scene.away_mode\" data-name=\"离家模式\" type=\"button\"><ha-icon icon=\"mdi:exit-run\"></ha-icon><b>离家</b><span>节能防护</span></button>\n            </div>\n          </section>\n        </aside>\n      </div>\n    </section>\n\n    <section class=\"page\" data-page-view=\"devices\">\n      <div class=\"subpage-head\"><ha-icon icon=\"mdi:devices\"></ha-icon><div><h2>设备总览</h2><p>html-pro-card 内部页面，不依赖自定义 JS 卡片。</p></div></div>\n      <div class=\"panel-grid\">\n        <div class=\"glass entity-row\"><div><b>客厅灯光</b><span>light.living_room_lights</span></div><strong id=\"device-list-light\">--</strong></div>\n        <div class=\"glass entity-row\"><div><b>卧室灯光</b><span>light.bedroom_lights</span></div><strong id=\"device-list-bedroom\">--</strong></div>\n        <div class=\"glass entity-row\"><div><b>厨房插座</b><span>switch.kitchen_socket</span></div><strong id=\"device-list-kitchen\">--</strong></div>\n        <div class=\"glass entity-row\"><div><b>客厅空调</b><span>climate.living_room_ac</span></div><strong id=\"device-list-climate\">--</strong></div>\n        <div class=\"glass entity-row\"><div><b>背景音乐</b><span>media_player.living_room_speaker</span></div><strong id=\"device-list-media\">--</strong></div>\n        <div class=\"glass entity-row\"><div><b>入户门锁</b><span>lock.front_door</span></div><strong id=\"device-list-lock\">--</strong></div>\n      </div>\n    </section>\n\n    <section class=\"page\" data-page-view=\"scenes\">\n      <div class=\"subpage-head\"><ha-icon icon=\"mdi:palette-swatch\"></ha-icon><div><h2>场景控制</h2><p>点击场景会弹出确认，减少误触。</p></div></div>\n      <div class=\"wide-grid\">\n        <button class=\"glass scene home\" data-scene=\"scene.home_mode\" data-name=\"回家模式\" type=\"button\"><ha-icon icon=\"mdi:home-import-outline\"></ha-icon><b>回家模式</b><span>灯光 / 空调 / 音乐</span></button>\n        <button class=\"glass scene night\" data-scene=\"scene.good_night\" data-name=\"晚安模式\" type=\"button\"><ha-icon icon=\"mdi:weather-night\"></ha-icon><b>晚安模式</b><span>关闭公共区域</span></button>\n        <button class=\"glass scene welcome\" data-scene=\"scene.welcome_home\" data-name=\"迎宾模式\" type=\"button\"><ha-icon icon=\"mdi:door-open\"></ha-icon><b>迎宾模式</b><span>客厅氛围灯</span></button>\n        <button class=\"glass scene away\" data-scene=\"scene.away_mode\" data-name=\"离家模式\" type=\"button\"><ha-icon icon=\"mdi:exit-run\"></ha-icon><b>离家模式</b><span>门锁 / 节能 / 防护</span></button>\n      </div>\n    </section>\n\n    <section class=\"page\" data-page-view=\"rooms\">\n      <div class=\"subpage-head\"><ha-icon icon=\"mdi:door\"></ha-icon><div><h2>房间状态</h2><p>按空间查看传感器与在线状态。</p></div></div>\n      <div class=\"panel-grid\">\n        <div class=\"glass entity-row\"><div><b>客厅</b><span id=\"rooms-living-detail\">--</span></div><ha-icon icon=\"mdi:sofa\"></ha-icon></div>\n        <div class=\"glass entity-row\"><div><b>卧室</b><span id=\"rooms-bedroom-detail\">--</span></div><ha-icon icon=\"mdi:bed\"></ha-icon></div>\n        <div class=\"glass entity-row\"><div><b>厨房</b><span id=\"rooms-kitchen-detail\">--</span></div><ha-icon icon=\"mdi:countertop\"></ha-icon></div>\n        <div class=\"glass entity-row\"><div><b>花园</b><span id=\"rooms-garden-detail\">--</span></div><ha-icon icon=\"mdi:flower\"></ha-icon></div>\n      </div>\n    </section>\n\n    <section class=\"page\" data-page-view=\"energy\">\n      <div class=\"subpage-head\"><ha-icon icon=\"mdi:lightning-bolt\"></ha-icon><div><h2>能源面板</h2><p>当前功率、今日用电和本月累计。</p></div></div>\n      <div class=\"panel-grid\">\n        <div class=\"glass\"><p class=\"muted\">当前功率</p><div class=\"energy-main\"><span id=\"energy-power\">--</span><small> W</small></div></div>\n        <div class=\"glass\"><p class=\"muted\">今日用电</p><div class=\"energy-main\"><span id=\"energy-today-2\">--</span><small> 度</small></div></div>\n        <div class=\"glass\"><p class=\"muted\">本月用电</p><div class=\"energy-main\"><span id=\"energy-month\">--</span><small> 度</small></div></div>\n      </div>\n    </section>\n\n    <section class=\"page\" data-page-view=\"logs\">\n      <div class=\"subpage-head\"><ha-icon icon=\"mdi:clipboard-text-clock\"></ha-icon><div><h2>运行日志</h2><p>仪表盘本地状态摘要。</p></div></div>\n      <div class=\"log-list\">\n        <div class=\"glass log\"><b>仪表盘已加载</b><p class=\"muted\">custom:html-pro-card / Minecraft Dashboard</p></div>\n        <div class=\"glass log warn\"><b>请替换实体 ID</b><p class=\"muted\">模板内使用的是公开占位实体。</p></div>\n        <div class=\"glass log danger\"><b>场景带确认</b><p class=\"muted\">执行前会弹窗确认，避免误触。</p></div>\n      </div>\n    </section>\n  </main>\n</div>\n\n<script>\n  const ENTITY = {\n    livingLight: \"light.living_room_lights\",\n    bedroomLight: \"light.bedroom_lights\",\n    gardenLight: \"light.garden_light_strip\",\n    kitchenSocket: \"switch.kitchen_socket\",\n    climate: \"climate.living_room_ac\",\n    media: \"media_player.living_room_speaker\",\n    lock: \"lock.front_door\",\n    door: \"binary_sensor.front_door_contact\",\n    livingPresence: \"binary_sensor.living_room_presence\",\n    bedroomPresence: \"binary_sensor.bedroom_presence\",\n    kitchenPresence: \"binary_sensor.kitchen_presence\",\n    livingTemp: \"sensor.living_room_temperature\",\n    livingHum: \"sensor.living_room_humidity\",\n    bedroomTemp: \"sensor.bedroom_temperature\",\n    bedroomHum: \"sensor.bedroom_humidity\",\n    kitchenTemp: \"sensor.kitchen_temperature\",\n    outdoorTemp: \"sensor.outdoor_temperature\",\n    outdoorHum: \"sensor.outdoor_humidity\",\n    pm25: \"sensor.pm25\",\n    power: \"sensor.current_power\",\n    energyToday: \"sensor.energy_cost_today\",\n    energyMonth: \"sensor.energy_cost_month\",\n    weather: \"weather.home\",\n    time: \"sensor.time\",\n    date: \"sensor.date\",\n  };\n\n  const val = (id, fallback = \"--\") => hass.states[id]?.state ?? fallback;\n  const attr = (id, key, fallback = \"\") => hass.states[id]?.attributes?.[key] ?? fallback;\n  const txt = (selector, value) => { const el = $(selector); if (el) el.textContent = value; };\n  const fmt = (value, digits = 1) => {\n    const number = Number.parseFloat(value);\n    return Number.isFinite(number) ? number.toFixed(digits) : \"--\";\n  };\n  const activeState = (state) => [\"on\", \"playing\", \"cool\", \"heat\", \"dry\", \"fan_only\", \"auto\", \"unlocked\"].includes(state);\n  const stateCN = (state) => {\n    const map = { on: \"开启\", off: \"关闭\", playing: \"播放中\", paused: \"暂停\", idle: \"待机\", cool: \"制冷\", heat: \"制热\", auto: \"自动\", locked: \"已锁\", unlocked: \"已开\", unavailable: \"离线\", unknown: \"未知\" };\n    return map[state] || state || \"--\";\n  };\n  const weatherCN = (state) => {\n    const map = { sunny: \"晴朗\", clear: \"晴朗\", cloudy: \"多云\", partlycloudy: \"局部多云\", rainy: \"下雨\", pouring: \"大雨\", snowy: \"下雪\", fog: \"有雾\", windy: \"有风\", hail: \"冰雹\", lightning: \"雷电\" };\n    return map[state] || state || \"--\";\n  };\n  const weatherIcon = (state) => {\n    const map = { sunny: \"mdi:weather-sunny\", clear: \"mdi:weather-sunny\", cloudy: \"mdi:weather-cloudy\", partlycloudy: \"mdi:weather-partly-cloudy\", rainy: \"mdi:weather-rainy\", pouring: \"mdi:weather-pouring\", snowy: \"mdi:weather-snowy\", fog: \"mdi:weather-fog\", windy: \"mdi:weather-windy\", hail: \"mdi:weather-hail\", lightning: \"mdi:weather-lightning\" };\n    return map[state] || \"mdi:weather-partly-cloudy\";\n  };\n  const setDevice = (selector, entityId, tone) => {\n    const el = $(selector);\n    if (!el) return;\n    const state = val(entityId, \"unknown\");\n    el.classList.remove(\"on-yellow\", \"on-blue\", \"on-purple\", \"on-green\", \"on-red\", \"off\", \"unavailable\");\n    if (state === \"unavailable\" || state === \"unknown\") el.classList.add(\"unavailable\");\n    else el.classList.add(activeState(state) ? tone : \"off\");\n  };\n  const setSwitch = (selector, on) => {\n    const el = $(selector);\n    if (!el) return;\n    el.classList.toggle(\"on\", Boolean(on));\n  };\n  const openMoreInfo = (entityId) => {\n    if (window.claw?.moreInfo) claw.moreInfo(entityId);\n    else if (window.claw?.fire) claw.fire(\"hass-more-info\", { entityId });\n    else root.dispatchEvent(new CustomEvent(\"hass-more-info\", { detail: { entityId }, bubbles: true, composed: true }));\n  };\n\n  function showPage(page) {\n    $$(\".nav button\").forEach((button) => button.classList.toggle(\"active\", button.dataset.page === page));\n    $$(\"[data-page-view]\").forEach((view) => view.classList.toggle(\"active\", view.dataset.pageView === page));\n  }\n\n  function bindOnce() {\n    if (root.__mcHtmlProDashboardBound) return;\n    root.__mcHtmlProDashboardBound = true;\n\n    $$(\".nav button\").forEach((button) => button.addEventListener(\"click\", () => showPage(button.dataset.page)));\n    $$(\"[data-page-jump]\").forEach((button) => button.addEventListener(\"click\", () => showPage(button.dataset.pageJump)));\n    $$(\"[data-action]\").forEach((button) => {\n      button.addEventListener(\"click\", () => {\n        const entityId = button.dataset.entity;\n        if (!entityId) return;\n        if (button.dataset.action === \"toggle\") {\n          const domain = entityId.split(\".\")[0];\n          hass.callService(domain, val(entityId) === \"on\" ? \"turn_off\" : \"turn_on\", { entity_id: entityId });\n        } else {\n          openMoreInfo(entityId);\n        }\n      });\n    });\n    $$(\"#weather-action\").forEach((button) => button.addEventListener(\"click\", () => openMoreInfo(ENTITY.weather)));\n    $$(\"[data-scene]\").forEach((button) => {\n      button.addEventListener(\"click\", () => {\n        const entityId = button.dataset.scene;\n        const name = button.dataset.name || entityId;\n        if (!entityId) return;\n        if (window.confirm && !window.confirm(\"确认执行场景：\" + name + \"？\")) return;\n        hass.callService(\"scene\", \"turn_on\", { entity_id: entityId });\n      });\n    });\n  }\n\n  function renderAll() {\n    const now = new Date();\n    txt(\"#clock-time\", val(ENTITY.time, now.toLocaleTimeString(\"zh-CN\", { hour: \"2-digit\", minute: \"2-digit\" })));\n    txt(\"#clock-date\", val(ENTITY.date, now.toLocaleDateString(\"zh-CN\")));\n\n    const weatherState = val(ENTITY.weather, \"--\");\n    txt(\"#weather-summary\", weatherCN(weatherState));\n    txt(\"#out-temp\", fmt(val(ENTITY.outdoorTemp), 1));\n    $(\"#weather-icon\")?.setAttribute(\"icon\", weatherIcon(weatherState));\n\n    const lightState = val(ENTITY.livingLight, \"unknown\");\n    txt(\"#light-badge\", stateCN(lightState));\n    txt(\"#light-state\", stateCN(lightState));\n    setSwitch(\"#light-switch\", lightState === \"on\");\n    setDevice(\"#card-light\", ENTITY.livingLight, \"on-yellow\");\n\n    const climateState = val(ENTITY.climate, \"unknown\");\n    const climateTemp = attr(ENTITY.climate, \"current_temperature\", val(ENTITY.livingTemp));\n    txt(\"#climate-badge\", stateCN(climateState));\n    txt(\"#climate-state\", fmt(climateTemp, 1) + \"°C\");\n    setSwitch(\"#climate-switch\", activeState(climateState));\n    setDevice(\"#card-climate\", ENTITY.climate, \"on-blue\");\n\n    const mediaState = val(ENTITY.media, \"unknown\");\n    txt(\"#media-state\", stateCN(mediaState));\n    setDevice(\"#card-media\", ENTITY.media, \"on-purple\");\n\n    const lockState = val(ENTITY.lock, \"unknown\");\n    txt(\"#lock-state\", stateCN(lockState));\n    $(\"#lock-icon\")?.setAttribute(\"icon\", lockState === \"unlocked\" ? \"mdi:lock-open-variant\" : \"mdi:lock\");\n    setDevice(\"#card-lock\", ENTITY.lock, lockState === \"unlocked\" ? \"on-red\" : \"on-green\");\n\n    const gardenState = val(ENTITY.gardenLight, \"unknown\");\n    txt(\"#garden-state\", stateCN(gardenState));\n    setSwitch(\"#garden-switch\", gardenState === \"on\");\n    setDevice(\"#card-garden\", ENTITY.gardenLight, \"on-yellow\");\n\n    txt(\"#env-temp\", fmt(val(ENTITY.livingTemp), 1));\n    txt(\"#env-hum\", fmt(val(ENTITY.livingHum), 0));\n    txt(\"#pm25-value\", fmt(val(ENTITY.pm25), 0));\n\n    const livingText = (val(ENTITY.livingPresence) === \"on\" ? \"有人\" : \"无人\") + \" · \" + fmt(val(ENTITY.livingTemp), 1) + \"°C · \" + fmt(val(ENTITY.livingHum), 0) + \"%\";\n    const bedroomText = (val(ENTITY.bedroomPresence) === \"on\" ? \"有人\" : \"无人\") + \" · \" + fmt(val(ENTITY.bedroomTemp), 1) + \"°C · \" + fmt(val(ENTITY.bedroomHum), 0) + \"%\";\n    const kitchenText = (val(ENTITY.kitchenPresence) === \"on\" ? \"有人\" : \"无人\") + \" · \" + fmt(val(ENTITY.kitchenTemp), 1) + \"°C\";\n    const gardenText = (gardenState === \"on\" ? \"灯带开\" : \"灯带关\") + \" · 湿度 \" + fmt(val(ENTITY.outdoorHum), 0) + \"%\";\n    txt(\"#room-living\", livingText);\n    txt(\"#room-bedroom\", bedroomText);\n    txt(\"#room-kitchen\", kitchenText);\n    txt(\"#room-garden\", gardenText);\n    txt(\"#rooms-living-detail\", livingText);\n    txt(\"#rooms-bedroom-detail\", bedroomText);\n    txt(\"#rooms-kitchen-detail\", kitchenText);\n    txt(\"#rooms-garden-detail\", gardenText);\n\n    txt(\"#device-list-light\", stateCN(lightState));\n    txt(\"#device-list-bedroom\", stateCN(val(ENTITY.bedroomLight, \"unknown\")));\n    txt(\"#device-list-kitchen\", stateCN(val(ENTITY.kitchenSocket, \"unknown\")));\n    txt(\"#device-list-climate\", stateCN(climateState));\n    txt(\"#device-list-media\", stateCN(mediaState));\n    txt(\"#device-list-lock\", stateCN(lockState));\n\n    const power = fmt(val(ENTITY.power), 0);\n    const today = fmt(val(ENTITY.energyToday), 1);\n    const month = fmt(val(ENTITY.energyMonth), 1);\n    txt(\"#energy-power\", power);\n    txt(\"#energy-today\", today);\n    txt(\"#energy-today-2\", today);\n    txt(\"#energy-month\", month);\n    const base = Number.parseFloat(power) || 0;\n    $$(\"#energy-bars span\").forEach((bar, index) => {\n      const height = Math.max(14, Math.min(92, 22 + ((base / 18 + index * 9) % 70)));\n      bar.style.height = height + \"%\";\n    });\n  }\n\n  bindOnce();\n  renderAll();\n  root._watchedEntities = Object.values(ENTITY);\n  root._onHassUpdate = renderAll;\n</script>\n"
            }
          ]
        }
      ]
    }
  }
}